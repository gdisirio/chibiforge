<?xml version="1.0" encoding="UTF-8"?>
<chibiforgeConfiguration
    xmlns="http://chibiforge/schema/config"
    toolVersion="1.0.0"
    schemaVersion="1.0">

  <targets>
    <target id="default"/>
  </targets>
  <components>
    <component id="org.chibios.chibiforge.components.kernel.port.stm32f4xx"/>
    <component id="org.chibios.chibiforge.components.board.stm32f4xx">
      <identification>
        <board_identifier>ST_STM32F4_DISCOVERY</board_identifier>
        <board_name>STMicroelectronics STM32F4-Discovery</board_name>
      </identification>
      <clock_settings>
        <vdd>300</vdd>
        <hse_oscillator_mode>Crystal</hse_oscillator_mode>
        <hse_frequency>8000000</hse_frequency>
        <lse_oscillator_mode>None</lse_oscillator_mode>
        <lse_frequency>32768</lse_frequency>
      </clock_settings>
      <phy_settings>
        <address>None</address>
        <id>MII_DP83848I_ID</id>
        <mode>RMII</mode>
      </phy_settings>
      <i_o_settings>
        <pins_list/>
      </i_o_settings>
      <initialization_code>
        <early_initialization_code/>
        <late_initialization_code/>
        <board_initialization_code/>
        <additional_code/>
      </initialization_code>
    </component>
  </components>
</chibiforgeConfiguration>

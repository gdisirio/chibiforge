<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://www.w3.org/2001/XMLSchema"
  xmlns:xs="http://www.w3.org/2001/XMLSchema"
  targetNamespace="http://chibiforge/schema/preset"
  xmlns:tns="http://chibiforge/schema/preset"
  elementFormDefault="qualified">

  <element name="preset" type="tns:presetType"></element>

  <complexType name="presetType">
    <sequence>
      <element name="sections" type="tns:sectionsType"></element>
    </sequence>
    <attribute name="name" type="xs:string" use="required"></attribute>
    <attribute name="id" type="xs:string" use="required"></attribute>
    <attribute name="version" type="xs:string" use="required"></attribute>
  </complexType>

  <complexType name="sectionsType">
    <sequence>
      <element name="section" type="tns:sectionType"
        maxOccurs="unbounded" minOccurs="1">
      </element>
    </sequence>
  </complexType>

  <complexType name="sectionType">
    <sequence>
      <element name="property" type="tns:propertyType"
        maxOccurs="unbounded" minOccurs="1"></element>
    </sequence>
    <attribute name="name" use="required">
      <simpleType>
        <restriction base="xs:string">
          <minLength value="1"></minLength>
        </restriction>
      </simpleType>
    </attribute>
  </complexType>

  <complexType name="itemType">
    <sequence>
      <element name="sections" type="tns:sectionsType" maxOccurs="1" minOccurs="1"></element>
    </sequence>
  </complexType>

  <complexType name="itemsType">
    <sequence>
      <element name="item" type="tns:itemType" maxOccurs="unbounded" minOccurs="0"></element>
    </sequence>
  </complexType>

  <complexType name="propertyType">
    <choice>
      <element name="items" type="tns:itemsType" maxOccurs="1"
        minOccurs="1">
      </element>
      <element name="value" type="xs:string" maxOccurs="1" minOccurs="1"></element>
    </choice>
    <attribute name="name" use="required">
      <simpleType>
        <restriction base="xs:string">
          <minLength value="1"></minLength>
        </restriction>
      </simpleType>
    </attribute>
    <attribute name="type" use="required">
      <simpleType>
        <restriction base="xs:string">
          <enumeration value="int"></enumeration>
          <enumeration value="string"></enumeration>
          <enumeration value="text"></enumeration>
          <enumeration value="bool"></enumeration>
          <enumeration value="enum"></enumeration>
          <enumeration value="list"></enumeration>
        </restriction>
      </simpleType>
    </attribute>
  </complexType>
</schema>

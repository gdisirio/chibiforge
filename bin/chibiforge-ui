#!/bin/bash
# ChibiForge UI wrapper
DIR="$(cd "$(dirname "$0")" && pwd)"
CACHE_ROOT="${XDG_CACHE_HOME:-$HOME/.cache}"
CACHE_DIR="$CACHE_ROOT/chibiforge/openjfx"
mkdir -p "$CACHE_DIR"
exec java -Djavafx.cachedir="$CACHE_DIR" -cp "$DIR/chibiforge-ui.jar:$DIR/chibiforge.jar" org.chibios.chibiforge.ui.ChibiForgeLauncher "$@"
